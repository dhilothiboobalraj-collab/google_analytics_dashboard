# =============================================================================
# Social Media Dashboard - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
# =============================================================================

# --- Meta (Facebook & Instagram) ---
USER_ACCESS_TOKEN=your_meta_user_access_token_here
FB_PAGE_ID=your_facebook_page_id_here
IG_USER_ID=your_instagram_user_id_here

# --- DigitalOcean AI (for AI Insights) ---
DIGITALOCEAN_API_KEY=your_digitalocean_api_key_here
DIGITALOCEAN_URL=https://inference.do-ai.run/v1
DIGITALOCEAN_MODEL=anthropic-claude-4.5-sonnet

# --- YouTube ---
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=your_youtube_channel_id_here

# --- Google Analytics 4 ---
GA4_PROPERTY_ID=your_ga4_property_id_here
GOOGLE_APPLICATION_CREDENTIALS=credentials/ga-service-account.json
GOOGLE_OAUTH_CREDENTIALS=client_secret.json
GOOGLE_OAUTH_TOKEN=token.json
